# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=https://crystallakewizards.com

# Google Analytics 4 — set to the GA4 Measurement ID (e.g. G-XXXXXXXXXX).
# When present, analytics loads automatically; leave blank to disable.
NEXT_PUBLIC_GA_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (transactional + comms email)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Crystal Lake Wizards <noreply@crystallakewizards.com>"
ALERT_EMAIL=info@crystallakewizards.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# QStash (async comms blast jobs + cron fan-out)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Cloudflare Turnstile (bot protection on public forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Vercel Cron — must match the value Vercel sends as `Authorization: Bearer
# <value>` on cron-triggered requests (set this same value in the Vercel
# project's env vars, Vercel wires it automatically once present).
CRON_SECRET=
